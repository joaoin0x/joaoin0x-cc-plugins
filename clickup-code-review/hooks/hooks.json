{
  "description": "ClickUp Code Review Plugin — auto-approve orchestration, file operations, and safe Bash commands",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|SendMessage|TeamCreate|TeamDelete",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/orchestration-auto-approve.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/file-ops-auto-approve.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/file-ops-auto-approve.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bash-safe-auto-approve.sh"
          }
        ]
      }
    ]
  }
}
